{
  "name": "agile-cms",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "db:up": "docker compose up -d --wait",
    "db:migrate": "pnpm --filter backend db:migrate",
    "db:seed": "pnpm --filter backend db:seed",
    "db:reset": "docker compose down -v && pnpm db:up && pnpm db:migrate && pnpm db:seed",
    "dev": "pnpm db:up && pnpm db:migrate && pnpm db:seed && pnpm -r --parallel run dev",
    "test": "pnpm --filter @cms/shared test && pnpm --filter frontend test",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4"
  }
}
